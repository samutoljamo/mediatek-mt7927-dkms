diff --git a/mt792x_mac.c b/mt792x_mac.c
index 71dec93..f3d7c34 100644
--- a/mt792x_mac.c
+++ b/mt792x_mac.c
@@ -146,8 +146,13 @@ struct mt76_wcid *mt792x_rx_get_wcid(struct mt792x_dev *dev, u16 idx,
 	if (unicast || !wcid)
 		return wcid;
 
-	if (!wcid->sta)
-		return NULL;
+	if (!wcid->sta) {
+		/* BSS self-STA WCID (sta=0): firmware uses this for
