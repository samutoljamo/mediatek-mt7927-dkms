wifi: mt76: mt7925: implement MT6639 mac_reset recovery path

The previous guard returned -EOPNOTSUPP for MT6639 because CLR_OWN and
WPDMA reset destroy the DMA ring configuration that mt6639_dma_init()
sets up. This left MT6639 unable to recover from firmware crashes
without a full module reload.

Implement mt7925e_mt6639_dma_reinit() which re-runs the CBTOP remap,
CBInfra init, PM handshake, and DMA reconfiguration needed after a
reset. The recovery path also skips the redundant fw_pmctrl/drv_pmctrl
cycle (already done in dma_reinit) and re-enables DBDC which firmware
requires after every boot.

Validated: restores 2.4/5/6 GHz connectivity after firmware-triggered
mac_reset.

Signed-off-by: marcin-fm <marcin-fm@users.noreply.github.com>
Signed-off-by: Javier Tia <floss@jetm.me>
---
diff --git i/mt7925/mt7925.h w/mt7925/mt7925.h
index b917915..ff62511 100644
--- i/mt7925/mt7925.h
+++ w/mt7925/mt7925.h
@@ -329,6 +329,7 @@ int mt7925_mcu_parse_response(struct mt76_dev *mdev, int cmd,
 
 int mt7925e_mac_reset(struct mt792x_dev *dev);
 int mt7925e_mcu_init(struct mt792x_dev *dev);
+int mt7925e_mt6639_dma_reinit(struct mt792x_dev *dev);
 void mt7925_mac_add_txs(struct mt792x_dev *dev, void *data);
 void mt7925_set_runtime_pm(struct mt792x_dev *dev);
 void mt7925_mcu_set_suspend_iter(void *priv, u8 *mac,
diff --git i/mt7925/pci.c w/mt7925/pci.c
index 68383ac..ca4cf83 100644
--- i/mt7925/pci.c
+++ w/mt7925/pci.c
@@ -431,6 +431,39 @@ static int mt6639_dma_init(struct mt792x_dev *dev)
 	return 0;
 }
 
+int mt7925e_mt6639_dma_reinit(struct mt792x_dev *dev)
+{
+	int ret;
+
+	mt6639_cbtop_remap(dev);
+
+	ret = mt6639_chip_init(dev);
+	if (ret)
+		return ret;
+
+	/* Keep MT6639 SET_OWN -> CLR_OWN ordering used in probe path. */
+	ret = mt792xe_mcu_fw_pmctrl(dev);
+	if (ret)
+		return ret;
+
+	ret = __mt792xe_mcu_drv_pmctrl(dev);
+	if (ret)
+		return ret;
+
+	ret = mt792x_wpdma_reset(dev, false);
+	if (ret)
+		return ret;
+
+	mt76_set(dev, MT_WFDMA0_GLO_CFG, MT_WFDMA0_GLO_CFG_ADDR_EXT_EN);
+	mt76_clear(dev, MT_WFDMA0_GLO_CFG, MT_WFDMA0_GLO_CFG_CSR_LBK_RX_Q_SEL_EN);
+	mt76_set(dev, MT_WFDMA0_GLO_CFG,
+		 MT_WFDMA0_GLO_CFG_FW_DWLD_BYPASS_DMASHDL);
+
+	mt76_wr(dev, MT_WFDMA0_HOST_INT_ENA, dev->mt76.mmio.irqmask);
+
+	return 0;
+}
+
 static const struct mt792x_irq_map mt6639_irq_map = {
 	.host_irq_enable = MT_WFDMA0_HOST_INT_ENA,
 	.tx = {
diff --git i/mt7925/pci_mac.c w/mt7925/pci_mac.c
index 9c66e48..b2f8b08 100644
--- i/mt7925/pci_mac.c
+++ w/mt7925/pci_mac.c
@@ -70,16 +70,9 @@ void mt7925_tx_token_put(struct mt792x_dev *dev)
 int mt7925e_mac_reset(struct mt792x_dev *dev)
 {
 	const struct mt792x_irq_map *irq_map = dev->irq_map;
+	bool mt6639 = is_mt6639(&dev->mt76);
 	int i, err;
 
-	/* MT6639: CLR_OWN and WPDMA reset destroy DMA ring configuration.
-	 * A full reset requires re-running mt6639_dma_init() which is not
-	 * yet implemented in the recovery path. */
-	if (is_mt6639(&dev->mt76)) {
-		dev_warn(dev->mt76.dev, "MT6639 mac_reset not supported, reload module to recover\n");
-		return -EOPNOTSUPP;
-	}
-
 	mt792xe_mcu_drv_pmctrl(dev);
 
 	mt76_connac_free_pending_tx_skbs(&dev->pm, NULL);
@@ -107,7 +100,12 @@ int mt7925e_mac_reset(struct mt792x_dev *dev)
 	mt7925_tx_token_put(dev);
 	idr_init(&dev->mt76.token);
 
-	mt792x_wpdma_reset(dev, true);
+	if (mt6639)
+		err = mt7925e_mt6639_dma_reinit(dev);
+	else
+		err = mt792x_wpdma_reset(dev, true);
+	if (err)
+		goto out;
 
 	mt76_for_each_q_rx(&dev->mt76, i) {
 		napi_enable(&dev->mt76.napi[i]);
@@ -132,13 +130,15 @@ int mt7925e_mac_reset(struct mt792x_dev *dev)
 		MT_INT_MCU_CMD);
 	mt76_wr(dev, MT_PCIE_MAC_INT_ENABLE, 0xff);
 
-	err = mt792xe_mcu_fw_pmctrl(dev);
-	if (err)
-		return err;
+	if (!mt6639) {
+		err = mt792xe_mcu_fw_pmctrl(dev);
+		if (err)
+			goto out;
 
-	err = __mt792xe_mcu_drv_pmctrl(dev);
-	if (err)
-		goto out;
+		err = __mt792xe_mcu_drv_pmctrl(dev);
+		if (err)
+			goto out;
+	}
 
 	err = mt7925_run_firmware(dev);
 	if (err)
@@ -152,9 +152,22 @@ int mt7925e_mac_reset(struct mt792x_dev *dev)
 	if (err)
 		goto out;
 
+	/* MT6639 requires explicit DBDC enable after each firmware boot.
+	 * Initial probe path does this in init.c; mirror it in reset flow.
+	 */
+	if (mt6639) {
+		err = mt7925_mcu_set_dbdc(&dev->mphy, true);
+		if (err) {
+			dev_warn(dev->mt76.dev,
+				 "MT6639 reset DBDC enable failed: %d\n", err);
+			err = 0;
+		}
+	}
+
 	err = __mt7925_start(&dev->phy);
 out:
 	clear_bit(MT76_RESET, &dev->mphy.state);
+	clear_bit(MT76_MCU_RESET, &dev->mphy.state);
 
 	mt76_worker_enable(&dev->mt76.tx_worker);
 
